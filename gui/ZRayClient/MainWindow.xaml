<Window x:Class="ZRayClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZRay" Width="520" Height="720"
        Background="{StaticResource BgPrimary}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Grid Margin="24">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Title -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,4">
                    <TextBlock Text="⚡ " FontSize="32"/>
                    <TextBlock Text="ZRay" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentRed}"/>
                </StackPanel>
                <TextBlock Text="Encrypted Proxy Tunnel" FontSize="13"
                           Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <!-- Status Card -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#888" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusText" Text="未连接" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Speed -->
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="↑ 上传" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="UpSpeed" Text="0 B/s" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="↓ 下载" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="DownSpeed" Text="0 B/s" FontSize="16" FontWeight="Bold"
                                           Foreground="#00B4D8" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="⚡ 连接" Foreground="{StaticResource TextSecondary}" FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock x:Name="ConnCount" Text="0" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource AccentRed}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Route Stats -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="DirectCount" Text="🎯 直连: 0"
                                       Foreground="{StaticResource AccentGreen}" FontSize="13"/>
                            <TextBlock Grid.Column="1" x:Name="ProxyCount" Text="🌐 代理: 0"
                                       Foreground="{StaticResource AccentRed}" FontSize="13" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Ports Card -->
                <Border Style="{StaticResource CardBorder}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource BgInput}" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="SmartPortText" Text="1080" FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource AccentRed}" HorizontalAlignment="Center"/>
                                <TextBlock Text="🎯 智能分流" FontSize="12" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="{StaticResource BgInput}" CornerRadius="8" Padding="12" Margin="6,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="GlobalPortText" Text="1081" FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource AccentRed}" HorizontalAlignment="Center"/>
                                <TextBlock Text="🌐 全局代理" FontSize="12" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Config Card -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="服务器配置" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"
                                   FontWeight="SemiBold" CharacterSpacing="80"/>
                        <TextBox x:Name="TxtServer" Style="{StaticResource InputBox}" Margin="0,0,0,8">
                            <TextBox.Tag>服务器地址</TextBox.Tag>
                        </TextBox>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtPort" Grid.Column="0" Style="{StaticResource InputBox}" Text="64433" Margin="0,0,4,8"/>
                            <TextBox x:Name="TxtHash" Grid.Column="1" Style="{StaticResource InputBox}" Margin="4,0,0,8"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ZA Link Import -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="ZA 链接导入" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,10"
                                   FontWeight="SemiBold" CharacterSpacing="80"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtZALink" Grid.Column="0" Style="{StaticResource InputBox}" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="导入" Style="{StaticResource AccentButton}" Click="OnImportLink" Padding="16,8"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Connect Button -->
                <Button x:Name="BtnConnect" Content="连 接" Style="{StaticResource AccentButton}"
                        Click="OnToggleConnect" Height="50" Margin="0,4,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
