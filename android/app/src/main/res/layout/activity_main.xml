<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Logo & Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚡ ZRay"
            android:textColor="#FFE94560"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encrypted Proxy Tunnel"
            android:textColor="#FF888888"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Status Card -->
        <LinearLayout
            android:id="@+id/card_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● 未连接"
                android:textColor="#FF888888"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FF666666"
                android:textSize="12sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Ports Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="代理端口"
                android:textColor="#FFAAAAAA"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_smart_port"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎯 SOCKS5  127.0.0.1:1080  (智能分流)"
                android:textColor="#FF53CF5E"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:background="#FF0A1128"
                android:padding="12dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_global_port"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌐 SOCKS5  127.0.0.1:1081  (全局代理)"
                android:textColor="#FFE94560"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:background="#FF0A1128"
                android:padding="12dp" />
        </LinearLayout>

        <!-- Config Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="服务器配置"
                android:textColor="#FFAAAAAA"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_server"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="服务器地址"
                android:textColor="#FFEEEEEE"
                android:textColorHint="#FF555555"
                android:textSize="15sp"
                android:background="#FF0A1128"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:inputType="text"
                android:singleLine="true" />

            <EditText
                android:id="@+id/et_port"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="端口 (默认 64433)"
                android:textColor="#FFEEEEEE"
                android:textColorHint="#FF555555"
                android:textSize="15sp"
                android:background="#FF0A1128"
                android:padding="12dp"
                android:layout_marginBottom="8dp"
                android:inputType="number"
                android:singleLine="true" />

            <EditText
                android:id="@+id/et_hash"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="用户密钥 (UserHash)"
                android:textColor="#FFEEEEEE"
                android:textColorHint="#FF555555"
                android:textSize="15sp"
                android:background="#FF0A1128"
                android:padding="12dp"
                android:inputType="textPassword"
                android:singleLine="true" />
        </LinearLayout>

        <!-- Buttons -->
        <Button
            android:id="@+id/btn_mode"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🎯 智能分流"
            android:textColor="#FFEEEEEE"
            android:textSize="15sp"
            android:backgroundTint="#FF16213E"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_connect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="连接"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#FF0F3460" />

    </LinearLayout>
</ScrollView>
